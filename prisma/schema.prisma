generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

// ===========================================
// DEPARTMENT
// ===========================================
model Department {
	id					Int				@id	@default(autoincrement())
	name				String			@unique

	users				User[]

	createdAt			DateTime		@default(now())
	updatedAt			DateTime		@updatedAt
}

// ===========================================
// USER & AUTHENTICATION
// ===========================================
model User {
	id					Int				@id @default(autoincrement())
	name				String
	username			String			@unique
	password			String
	role				String			@default("Requester")

	departmentId		Int?
	department			Department?		@relation(fields: [departmentId], references: [id])

	requests			TestRequest[]	@relation("RequestedBy")
	assignedRequests 	TestRequest[]	@relation("AssignedTo")

	createdAt			DateTime		@default(now())
	updatedAt			DateTime		@updatedAt
}

// ===========================================
// TEST TYPES	
// ===========================================
model TestType {
	id					Int				@id @default(autoincrement())
	name				String			@unique

	categories			TestCategory[]
	protocols			TestProtocol[]
	testPlans			TestPlan[]

	createdAt			DateTime		@default(now())
	updatedAt			DateTime		@updatedAt
}

// ===========================================
// TEST CATEGORIES
// ===========================================
model TestCategory {
	id					Int				@id	@default(autoincrement())
	name				String

	testTypeId			Int?
	testType			TestType?		@relation(fields: [testTypeId], references: [id])

	protocols			TestProtocol[]
	testPlans			TestPlan[]

	createdAt			DateTime		@default(now())
	updatedAt			DateTime		@updatedAt

	@@unique([name, testTypeId])
}

// ===========================================
// TEST PROTOCOLS
// ===========================================
model TestProtocol {
	id					Int				@id	@default(autoincrement())
	name				String
	productType			String			@default("SATL")
	testMethod			String			@db.NVarChar(Max)
	judgementCriteria	String			@db.NVarChar(Max)

	testTypeId			Int?
	testType			TestType?		@relation(fields: [testTypeId], references: [id], onUpdate: NoAction, onDelete: NoAction)

	testCategoryId		Int?
	testCategory		TestCategory?	@relation(fields: [testCategoryId], references: [id], onUpdate: NoAction, onDelete: NoAction)

	testPlans			TestPlan[]

	createdAt			DateTime		@default(now())
	updatedAt			DateTime		@updatedAt
}

// ===========================================
// PRODUCT/PART NAMES
// ===========================================
model ProductPart {
	id					Int				@id @default(autoincrement())
	name				String			@unique
	partNo				String?

	createdAt			DateTime		@default(now())
	updatedAt			DateTime		@updatedAt
}

// ===========================================
// SUPPLIER/CUSTOMER
// ===========================================
model SupplierCustomer {
	id					Int				@id @default(autoincrement())
	name				String			@unique

	createdAt			DateTime		@default(now())
	updatedAt			DateTime		@updatedAt
}

// ===========================================
// TESTING EQUIPMENTS
// ===========================================
model TestingEquipment {
	id					Int				@id @default(autoincrement())
	name				String			@unique
	calibrationDueDate	DateTime
	status				String			@default("ACTIVE")

	createdAt			DateTime		@default(now())
	updatedAt			DateTime		@updatedAt
}

// ===========================================
// TEST REQUESTS	
// ===========================================
model TestRequest {
	id					Int				@id	@default(autoincrement())
	samplePartName		String

	requesterId			Int
	requester			User			@relation("RequestedBy", fields: [requesterId], references: [id], onUpdate: NoAction, onDelete: NoAction)

	assignedToId		Int?
	assignedTo			User?			@relation("AssignedTo", fields: [assignedToId], references: [id], onUpdate: NoAction, onDelete: NoAction)

	createdAt			DateTime		@default(now())
	updatedAt			DateTime		@updatedAt
}

// ===========================================
// TEST PLANS
// ===========================================
model TestPlan {
	id					Int				@id @default(autoincrement())

	testTypeId			Int
	testType			TestType		@relation(fields: [testTypeId], references: [id], onUpdate: NoAction, onDelete: NoAction)

	testCategoryId		Int
	testCategory		TestCategory	@relation(fields: [testCategoryId], references: [id], onUpdate: NoAction, onDelete: NoAction)

	testProtocolId		Int
	testProtocol		TestProtocol	@relation(fields: [testProtocolId], references: [id], onUpdate: NoAction, onDelete: NoAction)

	createdAt			DateTime		@default(now())
	updatedAt			DateTime		@updatedAt
}