generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

// ===========================================
// DEPARTMENT
// ===========================================
model Department {
	id					Int				@id	@default(autoincrement())
	name				String			@unique

	users				User[]

	createdAt			DateTime		@default(now())
	updatedAt			DateTime		@updatedAt
}

// ===========================================
// USER & AUTHENTICATION
// ===========================================
model User {
	id					Int				@id @default(autoincrement())
	name				String
	username			String			@unique
	password			String
	role				String			@default("Requester")

	departmentId		Int?
	department			Department?		@relation(fields: [departmentId], references: [id])

	requests			TestRequest[]	@relation("RequestedBy")
	assignedRequests 	TestRequest[]	@relation("AssignedTo")
	capas			    CapaReport[]	@relation("CapaSubmittedBy")

	createdAt			DateTime		@default(now())
	updatedAt			DateTime		@updatedAt
}

// ===========================================
// TEST TYPES	
// ===========================================
model TestType {
	id					Int				@id @default(autoincrement())
	name				String			@unique

	categories			TestCategory[]
	protocols			TestProtocol[]
	testPlans			TestPlan[]

	createdAt			DateTime		@default(now())
	updatedAt			DateTime		@updatedAt
}

// ===========================================
// TEST CATEGORIES
// ===========================================
model TestCategory {
	id					Int				@id	@default(autoincrement())
	name				String

	testTypeId			Int?
	testType			TestType?		@relation(fields: [testTypeId], references: [id])

	protocols			TestProtocol[]
	testPlans			TestPlan[]

	createdAt			DateTime		@default(now())
	updatedAt			DateTime		@updatedAt

	@@unique([name, testTypeId])
}

// ===========================================
// TEST PROTOCOLS
// ===========================================
model TestProtocol {
	id					Int				@id	@default(autoincrement())
	name				String
	productType			String			@default("SATL")
	testMethod			String			@db.NVarChar(Max)
	judgementCriteria	String			@db.NVarChar(Max)

	testTypeId			Int?
	testType			TestType?		@relation(fields: [testTypeId], references: [id], onUpdate: NoAction, onDelete: NoAction)

	testCategoryId		Int?
	testCategory		TestCategory?	@relation(fields: [testCategoryId], references: [id], onUpdate: NoAction, onDelete: NoAction)

	testPlans			TestPlan[]

	createdAt			DateTime		@default(now())
	updatedAt			DateTime		@updatedAt
}

// ===========================================
// PRODUCT/PART NAMES
// ===========================================
model ProductPart {
	id					Int				@id @default(autoincrement())
	name				String			@unique
	partNo				String?

	createdAt			DateTime		@default(now())
	updatedAt			DateTime		@updatedAt
}

// ===========================================
// SUPPLIER/CUSTOMER
// ===========================================
model SupplierCustomer {
	id					Int				@id @default(autoincrement())
	name				String			@unique

	createdAt			DateTime		@default(now())
	updatedAt			DateTime		@updatedAt
}

// ===========================================
// TESTING EQUIPMENTS
// ===========================================
model TestingEquipment {
	id					Int				@id @default(autoincrement())
	name				String			@unique
	calibrationDueDate	DateTime
	status				String			@default("ACTIVE")

	// Occupancy details, similar to PlatformAvailability
	isAvailable			Boolean			@default(true)
	occupiedBy			String?
	testRequestId		Int?
	modelNo				String?
	occupiedUntil		DateTime?

	createdAt			DateTime		@default(now())
	updatedAt			DateTime		@updatedAt
}

// ===========================================
// TEST REQUESTS	
// ===========================================
model TestRequest {
	id                      	Int                     @id	@default(autoincrement())
	requestId               	String?                 @unique
	customerNameAddress     	String                  @db.NVarChar(Max)
	manufacturerNameAddress 	String                  @db.NVarChar(Max)
	customerContactDetails  	String
	sampleDescription       	String                  @db.NVarChar(Max)
	modelNo                 	String
	familyModel             	String?
	serialNumber            	String?
	productRating           	String
	sampleQty               	Int
	brandName               	String
	attachmentMention       	String?
	witnessRequired         	String                  @default("No")
	witnessPersonDetails    	String?
	testMethodRef           	String
	conformityStatement     	String                  @default("not Required")
	decisionRule            	String?
	collectBack             	String                  @default("No")
	status                  	String                  @default("PENDING_APPROVAL")
	remarks                 	String?                 @db.NVarChar(Max)

	requesterId             	Int
	requester               	User                    @relation("RequestedBy", fields: [requesterId], references: [id], onUpdate: NoAction, onDelete: NoAction)
	
	assignedToId            	Int?
	assignedTo              	User?                   @relation("AssignedTo", fields: [assignedToId], references: [id], onUpdate: NoAction, onDelete: NoAction)

	attachments             	TestRequestAttachment[]
	sampleInspections       	TestSampleInspection[]

	createdAt               	DateTime                @default(now())
	updatedAt               	DateTime                @updatedAt
}

// ===========================================
// TEST REQUEST ATTACHMENTS
// ===========================================
model TestRequestAttachment {
	id            		Int         	@id @default(autoincrement())
	fileName      		String	
	filePath      		String	
	fileSize      		Int	
	testRequestId 		Int	
	testRequest   		TestRequest 	@relation(fields: [testRequestId], references: [id], onUpdate: Cascade, onDelete: Cascade)
			
	createdAt     		DateTime    	@default(now())
	updatedAt     		DateTime    	@updatedAt
}

// ===========================================
// TEST PLANS
// ===========================================
model TestPlan {
	id					Int				@id @default(autoincrement())

	testTypeId			Int
	testType			TestType		@relation(fields: [testTypeId], references: [id], onUpdate: NoAction, onDelete: NoAction)

	testCategoryId		Int
	testCategory		TestCategory	@relation(fields: [testCategoryId], references: [id], onUpdate: NoAction, onDelete: NoAction)

	testProtocolId		Int
	testProtocol		TestProtocol	@relation(fields: [testProtocolId], references: [id], onUpdate: NoAction, onDelete: NoAction)

	createdAt			DateTime		@default(now())
	updatedAt			DateTime		@updatedAt
}

// ===========================================
// SAMPLE INSPECTIONS
// ===========================================
model TestSampleInspection {
	id             Int         @id @default(autoincrement())
	testRequestId  Int
	testRequest    TestRequest @relation(fields: [testRequestId], references: [id], onUpdate: Cascade, onDelete: Cascade)
	
	sampleIndex    Int
	allottedId     String
	remarks        String?     @db.NVarChar(Max)
	status         String      // 'PASSED' | 'FAILED'
	checks         String      @db.NVarChar(Max) // JSON representation of {checkpointId: 'Yes' | 'No' | 'N.A'}
	images         String?     @db.NVarChar(Max) // JSON array of base64 images
	
	createdAt      DateTime    @default(now())
	updatedAt      DateTime    @updatedAt
}

// ===========================================
// PLATFORM AVAILABILITY & RESERVATION
// ===========================================
model PlatformAvailability {
	id             Int         @id @default(autoincrement())
	stationNo      String         // S1 to S14
	platformNo     String         // P1 to P10
	isAvailable    Boolean     @default(true)
	
	// Occupancy details
	occupiedBy     String?     // e.g. "REQ-2026-1" or "Requester Name"
	testRequestId  Int?        // Optional reference to TestRequest
	modelNo        String?     // e.g. Dixon SMT-X90
	occupiedUntil  DateTime?   // Date/time until which it is occupied
	
	createdAt      DateTime    @default(now())
	updatedAt      DateTime    @updatedAt

	@@unique([stationNo, platformNo])
}

// ===========================================
// RELIABILITY DAILY CHECKSHEET ENTRIES
// ===========================================
model ReliabilityChecksheetEntry {
	id			Int			@id @default(autoincrement())
	planKey		String
	date		String
	data		String		@db.NVarChar(Max) // JSON string of columnId -> value

	createdAt	DateTime	@default(now())
	updatedAt	DateTime	@updatedAt

	@@unique([planKey, date])
}

// ===========================================
// LOCAL STORAGE SYNCHRONIZATION
// ===========================================
model LocalStorageSync {
	key			String		@id
	value		String		@db.NVarChar(Max)
	updatedAt	DateTime	@updatedAt
}

// ===========================================
// CAPA REPORTS
// ===========================================
model CapaReport {
	id                     Int      @id @default(autoincrement())
	capaId                 String   @unique

	relatedRequest         String
	productName            String
	nonConformity          String   @db.NVarChar(Max)
	rootCause              String   @db.NVarChar(Max)
	correctiveAction       String   @db.NVarChar(Max)
	preventiveAction       String   @db.NVarChar(Max)
	targetedDate           String
	status                 String   @default("OPEN")
	owner                  String?

	// Extended CAPA form fields
	partProduct            String?
	modelName              String?
	customerSupplier       String?
	date                   String?
	result                 String?
	title                  String?  @db.NVarChar(Max)
	improvementType        String?
	partName               String?
	problem                String?  @db.NVarChar(Max)
	model                  String?
	defectQty              String?
	venue                  String?
	imageUrl               String?  @db.NVarChar(Max)
	why1                   String?  @db.NVarChar(Max)
	why2                   String?  @db.NVarChar(Max)
	why3                   String?  @db.NVarChar(Max)
	why4                   String?  @db.NVarChar(Max)
	undetectedWhy1         String?  @db.NVarChar(Max)
	undetectedWhy2         String?  @db.NVarChar(Max)
	undetectedWhy3         String?  @db.NVarChar(Max)
	tempCountermeasure     String?  @db.NVarChar(Max)
	radicalCountermeasure  String?  @db.NVarChar(Max)
	inspectionControl      String?  @db.NVarChar(Max)
	processControl         String?  @db.NVarChar(Max)
	beforeImprovementImgUrl String? @db.NVarChar(Max)
	afterImprovementImgUrl  String? @db.NVarChar(Max)
	preventionImgUrl        String? @db.NVarChar(Max)
	remark                  String? @db.NVarChar(Max)

	submittedById          Int
	submittedBy            User     @relation("CapaSubmittedBy", fields: [submittedById], references: [id], onUpdate: NoAction, onDelete: NoAction)

	createdAt              DateTime @default(now())
	updatedAt              DateTime @updatedAt
}